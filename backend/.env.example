# Copy to .env and fill in your values (never commit .env)

# Required for AI features
GEMINI_API_KEY=your_gemini_api_key

# Required in production — generate with: openssl rand -hex 32
SECRET_KEY=your-long-random-secret-key

# Comma-separated frontend URLs allowed to call the API (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (SQLite default; use Postgres URL on Render for persistence)
DATABASE_URL=sqlite+aiosqlite:///./wellness.db

# Gmail SMTP — App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Optional: alert thresholds (0–10 scale)
STRESS_ALERT_THRESHOLD=7.0
ANXIETY_ALERT_THRESHOLD=7.0
